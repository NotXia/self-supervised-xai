{
    "model_name": "image-classifier",
    "model_args": {
        "image_encoder_card": "google/vit-base-patch16-224-in21k",
        "out_classes": 10,
        
        "classifier_lr": 1e-4,
        "finetune_lr": 1e-5,
        "masker_lr": 1e-4,

        "skip_masker_relu": false,
        "skip_masker_sigmoid": false,
        "skip_masker_rescale": false,
        "skip_loss_penalty_binary": false,
        "skip_loss_penalty_magnitude": true
    },
    "dataset_name": "imagenette",
    "dataset_args": {}
}